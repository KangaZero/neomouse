#!/usr/bin/env bash
# Pre-push: optimized release build gate.
#
# A release build is a *different* compile from the debug build that
# `swift test` runs in pre-commit (whole-module optimization, release-only
# code paths), so it can surface breakage the per-commit hook misses. It's
# too slow to run on every commit, but push is infrequent — this is the
# natural "don't push red to CI" gate.
#
# Scope is deliberately single-arch and toolchain-agnostic: the universal
# (arm64 + x86_64) build, `lipo` slice check, and `nix flake check` need full
# Xcode / Nix and run in CI (.github/workflows/ci.yml), not here.
#
# Enable with: scripts/setup-hooks.sh (sets core.hooksPath=.githooks).
# Bypass a one-off push with: git push --no-verify

set -euo pipefail

step() { printf "\n\033[1;34m==>\033[0m %s\n" "$1"; }
fail() { printf "\033[1;31merror:\033[0m %s\n" "$1" >&2; exit 1; }

command -v swift >/dev/null || fail "swift toolchain not found"

step "Building release binary (swift build -c release)"
swift build -c release || fail "Release build failed. Fix before pushing (or bypass with: git push --no-verify)."

echo
echo "Pre-push checks passed."
