{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opim.nvim/neomouse/settings.schema.json",
  "title": "Neomouse settings",
  "description": "Configuration for neomouse. Mirrors the nested `Config` struct in Sources/neomouseConfig/config.swift.",
  "type": "object",
  "additionalProperties": false,
  "required": ["grid", "motion", "visual", "gesture", "commands", "configuration"],
  "properties": {
    "grid": { "$ref": "#/$defs/grid" },
    "motion": { "$ref": "#/$defs/motion" },
    "visual": { "$ref": "#/$defs/visual" },
    "gesture": { "$ref": "#/$defs/gesture" },
    "commands": { "$ref": "#/$defs/commands" },
    "configuration": { "$ref": "#/$defs/configuration" },
    "theme": { "$ref": "#/$defs/theme" }
  },
  "$defs": {
    "grid": {
      "type": "object",
      "description": "Find-mode grid geometry and labels.",
      "additionalProperties": false,
      "required": [
        "inset",
        "divisions",
        "inner_divisions",
        "find_mode_characters",
        "find_mode_inner_characters",
        "is_always_show_inner_characters"
      ],
      "properties": {
        "inset": {
          "type": "number",
          "minimum": 0,
          "default": 10.0,
          "description": "Pixels between the grid bounds and the screen edges."
        },
        "divisions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 5,
          "description": "Outer grid cells per axis. Capped at 26 (alphabet length)."
        },
        "inner_divisions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 3,
          "description": "Inner grid cells per axis within a selected outer cell."
        },
        "find_mode_characters": {
          "type": "string",
          "pattern": "^[a-z0-9]+$",
          "default": "abcdefghijklmnopqrstuvwxyz",
          "description": "Outer-cell labels. Length must be >= divisions^2."
        },
        "find_mode_inner_characters": {
          "type": "string",
          "pattern": "^[a-z0-9]+$",
          "default": "abcdefghijklmnopqrstuvwxyz",
          "description": "Inner-cell labels. Length must be >= inner_divisions^2."
        },
        "is_always_show_inner_characters": {
          "type": "boolean",
          "default": true,
          "description": "Render inner-cell labels alongside outer labels at first keypress."
        }
      }
    },
    "motion": {
      "type": "object",
      "description": "Cursor motion behavior in normal mode.",
      "additionalProperties": false,
      "required": [
        "rows_on_screen",
        "columns_on_screen",
        "is_clamp_cursor_to_current_screen"
      ],
      "properties": {
        "rows_on_screen": {
          "oneOf": [
            { "type": "integer", "exclusiveMinimum": 0 },
            { "type": "string", "enum": ["automatic"] }
          ],
          "default": "automatic",
          "description": "Vertical grid resolution. Integer cell count, or 'automatic' to derive from screen height (~20pt per cell). Step size for j/k = usable height / rows."
        },
        "columns_on_screen": {
          "oneOf": [
            { "type": "integer", "exclusiveMinimum": 0 },
            { "type": "string", "enum": ["automatic"] }
          ],
          "default": "automatic",
          "description": "Horizontal grid resolution. Integer cell count, or 'automatic' to square cells against the resolved row height. Step size for h/l = usable width / columns."
        },
        "is_clamp_cursor_to_current_screen": {
          "type": "boolean",
          "default": false,
          "description": "If true, hjkl motions stay within the active display."
        }
      }
    },
    "visual": {
      "type": "object",
      "description": "Visual selection appearance.",
      "additionalProperties": false,
      "required": ["minimum_highlight_width"],
      "properties": {
        "minimum_highlight_width": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Floor pixel width below which the highlight is suppressed."
        }
      }
    },
    "gesture": {
      "type": "object",
      "description": "Pinch-zoom and rotation gesture parameters.",
      "additionalProperties": false,
      "required": [
        "zoom_step_value",
        "increments_per_gesture",
        "degrees_to_rotate"
      ],
      "properties": {
        "zoom_step_value": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 10,
          "default": 0.1,
          "description": "Zoom delta per `+`/`-` press. Allowed range: 0.01..10."
        },
        "increments_per_gesture": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Sub-events emitted per logical gesture for smoother animation."
        },
        "degrees_to_rotate": {
          "type": "number",
          "default": 90,
          "description": "Degrees rotated per `r`/`R` press. Negative values reverse direction."
        }
      }
    },
    "commands": {
      "type": "object",
      "description": "Ex-style commands exposed in command-line mode.",
      "additionalProperties": false,
      "required": ["available"],
      "properties": {
        "available": {
          "type": "array",
          "uniqueItems": true,
          "description": "Whitelist of commands. Must match the `Command` enum in Sources/neomouseConfig/config.swift.",
          "items": {
            "type": "string",
            "enum": [
              "numbers", "nu",
              "relativenumbers", "rnu",
              "cursorline", "cul",
              "cursorcolumn", "cuc",
              "cursor", "c",
              "registers", "reg",
              "jumps", "ju",
              "help", "h",
              "delmarks", "delm",
              "marks", "m",
              "restart", "r",
              "q", "quit"
            ]
          }
        }
      }
    },
    "configuration": {
      "type": "object",
      "description": "Process-wide knobs that don't belong with motion/visual/etc.",
      "additionalProperties": false,
      "required": [
        "is_disable_key_input",
        "max_session_count",
        "new_session_on_open",
        "mode_on_start"
      ],
      "properties": {
        "is_disable_key_input": {
          "type": "boolean",
          "default": true,
          "description": "If true, the CGEventTap runs in .defaultTap mode and swallows most plain keypresses while neomouse is active. If false, listen-only — every key passes through."
        },
        "max_session_count": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "Cap on the number of session rows retained in the DB."
        },
        "new_session_on_open": {
          "type": "boolean",
          "default": false,
          "description": "Open a fresh session on launch instead of resuming the most recent one."
        },
        "mode_on_start": {
          "type": "string",
          "enum": ["disabled", "normal", "find", "command", "menu"],
          "default": "normal",
          "description": "Which mode neomouse boots into. 'disabled' leaves it dormant until Cmd-E activates."
        }
      }
    },
    "theme": {
      "type": "object",
      "description": "Per-element visual overrides for every UI overlay except the menu-bar icon. Every section is optional; omitted keys keep the built-in defaults.",
      "additionalProperties": false,
      "properties": {
        "grid": {
          "type": "object",
          "additionalProperties": false,
          "description": "Shared theme for GridOverlay (find-mode big grid) and CursorSurroundedGridOverlay (special-find dense grid).",
          "properties": {
            "background": { "$ref": "#/$defs/themeColor" },
            "outer_line_color": { "$ref": "#/$defs/themeColor" },
            "outer_label_color": { "$ref": "#/$defs/themeColor" },
            "outer_label_font": { "$ref": "#/$defs/themeFont" },
            "inner_line_color": { "$ref": "#/$defs/themeColor" },
            "inner_faint_line_color": { "$ref": "#/$defs/themeColor" },
            "inner_label_color": { "$ref": "#/$defs/themeColor" },
            "inner_label_font": { "$ref": "#/$defs/themeFont" },
            "cursor_surrounded_box_size": { "type": "number", "exclusiveMinimum": 0 },
            "cursor_surrounded_divisions": { "type": "integer", "minimum": 1, "maximum": 12 },
            "cursor_surrounded_label_font": { "$ref": "#/$defs/themeFont" }
          }
        },
        "numbers_overlay": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "direction": { "type": "string", "enum": ["left", "right"] },
            "gutter_background": { "$ref": "#/$defs/themeColor" },
            "cursor_line_highlight": { "$ref": "#/$defs/themeColor" },
            "cursor_column_highlight": { "$ref": "#/$defs/themeColor" },
            "cursor_text_color": { "$ref": "#/$defs/themeColor" },
            "text_color": { "$ref": "#/$defs/themeColor" },
            "font": { "$ref": "#/$defs/themeFont" },
            "gutter_width": { "type": "number", "exclusiveMinimum": 0 },
            "column_strip_height": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "command_line": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anchor": { "$ref": "#/$defs/themeAnchor" },
            "x_offset": { "type": "number" },
            "y_offset": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "corner_radius": { "type": "number", "minimum": 0 },
            "text_font": { "$ref": "#/$defs/themeFont" },
            "text_color": { "$ref": "#/$defs/themeColor" },
            "prefix_color": { "$ref": "#/$defs/themeColor" },
            "suggestion_font": { "$ref": "#/$defs/themeFont" },
            "suggestion_text_color": { "$ref": "#/$defs/themeColor" },
            "suggestion_highlight": { "$ref": "#/$defs/themeColor" },
            "material": { "$ref": "#/$defs/themeMaterial" }
          }
        },
        "marks_menu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anchor": { "$ref": "#/$defs/themeAnchor" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "corner_radius": { "type": "number", "minimum": 0 },
            "material": { "$ref": "#/$defs/themeMaterial" },
            "header_font": { "$ref": "#/$defs/themeFont" },
            "mark_label_font": { "$ref": "#/$defs/themeFont" },
            "cell_font": { "$ref": "#/$defs/themeFont" },
            "empty_message_font": { "$ref": "#/$defs/themeFont" },
            "selected_row_background": { "$ref": "#/$defs/themeColor" },
            "row_padding_x": { "type": "number", "minimum": 0 },
            "row_padding_y": { "type": "number", "minimum": 0 }
          }
        },
        "register_menu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anchor": { "$ref": "#/$defs/themeAnchor" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "corner_radius": { "type": "number", "minimum": 0 },
            "material": { "$ref": "#/$defs/themeMaterial" },
            "card_width": { "type": "number", "exclusiveMinimum": 0 },
            "card_height": { "type": "number", "exclusiveMinimum": 0 },
            "card_padding_x": { "type": "number", "minimum": 0 },
            "card_padding_y": { "type": "number", "minimum": 0 },
            "view_padding": { "type": "number", "minimum": 0 },
            "search_font": { "$ref": "#/$defs/themeFont" },
            "app_name_font": { "$ref": "#/$defs/themeFont" },
            "register_label_font": { "$ref": "#/$defs/themeFont" },
            "card_text_font": { "$ref": "#/$defs/themeFont" },
            "badge_font": { "$ref": "#/$defs/themeFont" },
            "register_badge_background": { "$ref": "#/$defs/themeColor" },
            "selected_card_border": { "$ref": "#/$defs/themeColor" },
            "unselected_card_border": { "$ref": "#/$defs/themeColor" },
            "card_shadow_selected": { "$ref": "#/$defs/themeColor" },
            "card_shadow_unselected": { "$ref": "#/$defs/themeColor" },
            "content_background": { "$ref": "#/$defs/themeColor" }
          }
        },
        "help_dialog": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anchor": { "$ref": "#/$defs/themeAnchor" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "padding": { "type": "number", "minimum": 0 },
            "header_color": { "$ref": "#/$defs/themeColor" },
            "header_font": { "$ref": "#/$defs/themeFont" },
            "keybind_font": { "$ref": "#/$defs/themeFont" },
            "description_color": { "$ref": "#/$defs/themeColor" }
          }
        },
        "visual_highlight": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fill": { "$ref": "#/$defs/themeColor" }
          }
        },
        "toast": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anchor": { "$ref": "#/$defs/themeAnchor" },
            "x_offset": { "type": "number" },
            "y_offset": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "corner_radius": { "type": "number", "minimum": 0 },
            "padding_x": { "type": "number", "minimum": 0 },
            "padding_y": { "type": "number", "minimum": 0 },
            "outer_padding": { "type": "number", "minimum": 0 },
            "background": { "$ref": "#/$defs/themeColor" },
            "text_color": { "$ref": "#/$defs/themeColor" },
            "text_font": { "$ref": "#/$defs/themeFont" }
          }
        },
        "key_cast": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anchor": { "$ref": "#/$defs/themeAnchor" },
            "x_offset": { "type": "number" },
            "y_offset": { "type": "number" },
            "width": { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "exclusiveMinimum": 0 },
            "corner_radius": { "type": "number", "minimum": 0 },
            "padding_x": { "type": "number", "minimum": 0 },
            "padding_y": { "type": "number", "minimum": 0 },
            "background": { "$ref": "#/$defs/themeColor" },
            "text_color": { "$ref": "#/$defs/themeColor" },
            "border_color": { "$ref": "#/$defs/themeColor" },
            "shadow_color": { "$ref": "#/$defs/themeColor" },
            "text_font": { "$ref": "#/$defs/themeFont" }
          }
        }
      }
    },
    "themeColor": {
      "type": "string",
      "pattern": "^#?(?:[0-9a-fA-F]{3,4}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$",
      "description": "Hex color: '#rgb', '#rgba', '#rrggbb', or '#rrggbbaa'. The leading # is optional."
    },
    "themeFont": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "family": {
          "type": "string",
          "description": "Empty string = system font. Otherwise an installed font name (e.g. 'SF Mono', 'Menlo')."
        },
        "size": { "type": "number", "exclusiveMinimum": 0 },
        "weight": {
          "type": "string",
          "enum": [
            "ultra_light", "thin", "light", "regular",
            "medium", "semibold", "bold", "heavy", "black"
          ]
        },
        "design": {
          "type": "string",
          "enum": ["default", "monospaced", "serif", "rounded"],
          "description": "Only applies when family is empty (system font)."
        }
      }
    },
    "themeAnchor": {
      "type": "string",
      "enum": [
        "top", "top_left", "top_right",
        "center", "center_left", "center_right",
        "bottom", "bottom_left", "bottom_right"
      ],
      "description": "Where on the active screen's visible frame the overlay anchors. Combine with offset_x / offset_y to push inward from the anchor edge."
    },
    "themeMaterial": {
      "type": "string",
      "enum": ["ultra_thin", "thin", "regular", "thick", "ultra_thick", "bar", "hud"],
      "description": "SwiftUI Material flavor — controls the level of background blur for translucent panels."
    }
  }
}
